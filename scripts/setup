#!/bin/bash
set -e pipefail # Exit immediately if any command fails

echo "Updating system..."
sudo apt-get update

# Dynamically install the correct clipboard tool
if [ -n "$WAYLAND_DISPLAY" ]; then
  echo "Wayland detected. Installing wl-clipboard..."
  sudo apt-get install -y wl-clipboard
else
  echo "X11 (or no Wayland) detected. Installing xclip..."
  sudo apt-get install -y xclip
fi

echo "Setting up mise environment..."
# Only run mise if the mise.toml file actually exists in this project
if [ -f "mise.toml" ]; then
  echo "Found mise.toml! Trusting and installing..."
  /usr/local/bin/mise trust mise.toml
  /usr/local/bin/mise install
else
  echo "No mise.toml found in this project. Skipping mise setup."
fi

echo "Devcontainer setup complete!"
